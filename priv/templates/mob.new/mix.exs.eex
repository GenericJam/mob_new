defmodule <%= module_name %>.MixProject do
  use Mix.Project

  def project do
    [
      app: :<%= app_name %>,
      version: "0.1.0",
      elixir: "~> 1.18",
      start_permanent: false,
      deps: deps(),
      erlc_paths: ["src"],
      erlc_options: [:debug_info]
    ]
  end

  def application do
    [extra_applications: [:logger]]
  end

  defp deps do
    [
      <%= mob_dep %>,
      <%= mob_dev_dep %>,
      {:ecto_sqlite3, "~> 0.18"}
    ]
  end
end
